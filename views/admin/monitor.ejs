<div>
  <header class="page-header">
    <a class="back-link" href="/">← Home</a>
    <div>
      <h1>Admin Monitor</h1>
      <p class="muted">Basic monitoring output (no auth required yet).</p>
    </div>
  </header>

  <section class="panel">
    <h2>Search User by ID</h2>
    <form method="GET" action="/admin/user-search">
      <input type="number" name="id" placeholder="Enter user ID" required />
      <button type="submit">Go</button>
    </form>
  </section>

  <section class="panel">
    <h2>Server Uptime</h2>
    <pre class="pre"><%= uptimeOutput %></pre>
  </section>

  <section class="panel">
    <h2>Latest Audit Logs (DB)</h2>

    <% if (!latestLogs || latestLogs.length === 0) { %>
      <p class="muted">No audit logs found.</p>
    <% } else { %>
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Time</th>
              <th>Severity</th>
              <th>Event</th>
              <th>Actor</th>
              <th>IP Address</th>
              <th>Message</th>
            </tr>
          </thead>
          <tbody>
            <% latestLogs.forEach(log => { %>
              <tr class="log-row" data-metadata='<%= log.metadata_json || "{}" %>'>
                <td><%= log.created_at %></td>
                <td><span class="badge badge-<%= log.severity %>"><%= log.severity %></span></td>
                <td><%= log.event_type %></td>
                <td><%= log.actor_user_id || '-' %></td>
                <td><%= log.ip_address || '-' %></td>
                <td><%= log.message_summary || log.message || '' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>

  <section class="panel">
    <h2>Application Log (File)</h2>
    <p class="muted">Path: <code><%= logPath %></code></p>

    <% if (!fileLogTail) { %>
      <p class="muted">No log file found yet. Create logs/app.log or add request logging middleware.</p>
    <% } else { %>
      <pre class="pre"><%= fileLogTail %></pre>
    <% } %>
  </section>

  <!-- Modal for showing audit log metadata -->
  <div id="metadataModalBackdrop" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.35); z-index:999;"></div>
  <div id="metadataModal" style="display:none; position:fixed; inset:3vh 4vw; background:#fff; border:1px solid #ccc; box-shadow:0 8px 24px rgba(0,0,0,0.25); padding:1rem; z-index:1000; overflow:hidden;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
      <h3 style="margin:0;">Metadata</h3>
      <button id="metadataCloseBtn" type="button">Close</button>
    </div>
    <pre id="metadataContent" style="white-space: pre-wrap; max-height: calc(94vh - 88px); overflow:auto; margin:0; font-size:12px; line-height:1.35;"></pre>
  </div>

  <script>
    // Attach click listeners to all audit log rows
    document.querySelectorAll('.log-row').forEach(row => {
      row.addEventListener('click', () => {
        const metadataJson = row.dataset.metadata || '{}';
        let metadata;

        try {
          metadata = JSON.parse(metadataJson);
        } catch (e) {
          metadata = { error: 'Invalid JSON' };
        }

        document.getElementById('metadataContent').textContent = JSON.stringify(metadata, null, 2);
        document.getElementById('metadataModalBackdrop').style.display = 'block';
        document.getElementById('metadataModal').style.display = 'block';
      });
    });

    function closeMetadataModal() {
      document.getElementById('metadataModal').style.display = 'none';
      document.getElementById('metadataModalBackdrop').style.display = 'none';
    }

    document.getElementById('metadataCloseBtn').addEventListener('click', closeMetadataModal);
    document.getElementById('metadataModalBackdrop').addEventListener('click', closeMetadataModal);
  </script>
</div>
